# Copy this file to .env and fill in real values. Never commit the real .env.

POSTGRES_USER=studyops
POSTGRES_PASSWORD=change_me
POSTGRES_DB=studyops

# Built from the Postgres values above, using the "postgres" service name as host
DATABASE_URL=postgresql://studyops:change_me@postgres:5432/studyops

# Generate a strong one with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_long_random_string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3000